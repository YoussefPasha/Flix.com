PORT=3000

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=flix_db


# For production (uncomment and set secure values)
# DATABASE_HOST=postgres
# DATABASE_PORT=5432
# DATABASE_USER=flix_user
# DATABASE_PASSWORD=your_very_secure_password_here_minimum_16_chars
# DATABASE_NAME=flix_production_db

JWT_SECRET=dev-secret-key-change-in-production

# Production (uncomment and use a strong secret)
# JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long_random_string
# JWT_EXPIRATION=7d

# ==============================================
# API Configuration
# ==============================================
# API Version (default: v1)
API_VERSION=v1

# CORS Origins (comma-separated)
# Development
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Production (uncomment and set your domain)
# CORS_ORIGINS=https://flix.com,https://www.flix.com

# ==============================================
# Traefik/Domain Configuration (Production)
# ==============================================
# Your backend domain for Traefik routing
BACKEND_DOMAIN=api.flix.com

# Email for Let's Encrypt SSL certificates
ACME_EMAIL=youssefbashafcis@gmail.com
